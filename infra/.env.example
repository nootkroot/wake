# ---------- Backend (FastAPI) ----------
DEBUG=false
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/postgres
ADMIN_TOKEN=replace-with-a-strong-token

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter (chat completions for scoring + translation)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:exacto
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_REFERER=https://wake.local
OPENROUTER_APP_TITLE=Wake

# Census API (no key needed; namespaced for cache busting / mirror)
CENSUS_API_BASE=https://api.census.gov/data

# Score fuzzing
FUZZ_SIGMA=3.0

# Moderation
DEFAULT_REPORT_THRESHOLD=5

# Feature flags
ENABLE_IMAGE_UPLOAD=true
ENABLE_AI_ANALYSIS_ON_DRAFT=true
ENABLE_LEGISLATOR_DASHBOARD=true

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000

# ---------- Frontend (Next.js) ----------
NEXT_PUBLIC_API_BASE=http://localhost:8000/api/v1
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_DEFAULT_CITY="Seattle"
NEXT_PUBLIC_DEFAULT_LAT=47.6062
NEXT_PUBLIC_DEFAULT_LNG=-122.3321
